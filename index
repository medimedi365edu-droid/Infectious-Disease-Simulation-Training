<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>인플루엔자 위기대응 협력 훈련 — 도상훈련(TTX)</title>
<style>
  :root {
    --primary: #1a3a5c;
    --phase1: #e67e22;
    --phase2: #c0392b;
    --phase3: #8e44ad;
    --feedback: #27ae60;
    --bg: #f0f4f8;
    --card: #ffffff;
    --border: #d1dbe8;
    --text: #1e2a38;
    --muted: #6b7c93;
    --radius: 10px;
    --shadow: 0 2px 12px rgba(0,0,0,0.08);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Malgun Gothic', '맑은 고딕', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

  /* ── LOGIN SCREEN ── */
  #screen-login {
    display: flex; align-items: center; justify-content: center;
    min-height: 100vh; background: linear-gradient(135deg, #1a3a5c 0%, #2c5f8a 60%, #1a5276 100%);
  }
  .login-card {
    background: white; border-radius: 18px; padding: 48px 40px;
    width: 440px; max-width: 95vw; box-shadow: 0 8px 40px rgba(0,0,0,0.25);
  }
  .login-logo { text-align: center; margin-bottom: 28px; }
  .login-logo .icon { font-size: 52px; display: block; margin-bottom: 8px; }
  .login-logo h1 { font-size: 22px; font-weight: 700; color: var(--primary); line-height: 1.4; }
  .login-logo p { font-size: 13px; color: var(--muted); margin-top: 4px; }
  .form-group { margin-bottom: 18px; }
  .form-group label { display: block; font-size: 13px; font-weight: 600; color: var(--muted); margin-bottom: 6px; }
  .form-group input, .form-group select {
    width: 100%; padding: 11px 14px; border: 2px solid var(--border); border-radius: 8px;
    font-size: 15px; font-family: inherit; color: var(--text);
    transition: border-color 0.2s;
  }
  .form-group input:focus, .form-group select:focus { outline: none; border-color: var(--primary); }
  .role-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 6px; }
  .role-btn {
    padding: 12px 8px; border: 2px solid var(--border); border-radius: 8px; cursor: pointer;
    text-align: center; font-size: 13px; font-family: inherit; background: white;
    transition: all 0.15s; line-height: 1.4;
  }
  .role-btn:hover { border-color: var(--primary); background: #f0f6ff; }
  .role-btn.selected { border-color: var(--primary); background: var(--primary); color: white; }
  .role-btn .role-icon { font-size: 20px; display: block; margin-bottom: 4px; }
  .role-btn.moderator-btn { grid-column: span 2; }
  .btn-join {
    width: 100%; padding: 14px; background: var(--primary); color: white;
    border: none; border-radius: 10px; font-size: 16px; font-weight: 700;
    cursor: pointer; font-family: inherit; margin-top: 8px; transition: background 0.2s;
  }
  .btn-join:hover { background: #244f7a; }
  .btn-join:disabled { background: #aaa; cursor: not-allowed; }
  .session-hint { font-size: 12px; color: var(--muted); text-align: center; margin-top: 14px; }

  /* ── MAIN EXERCISE SCREEN ── */
  #screen-exercise { display: none; flex-direction: column; min-height: 100vh; }

  /* Header */
  .ex-header {
    background: var(--primary); color: white; padding: 0 24px;
    display: flex; align-items: center; gap: 16px; height: 64px; position: sticky; top: 0; z-index: 100;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }
  .ex-header .title { font-size: 16px; font-weight: 700; flex: 1; }
  .ex-header .title span { font-size: 12px; opacity: 0.7; display: block; }
  .phase-badge {
    padding: 5px 14px; border-radius: 20px; font-size: 13px; font-weight: 700;
    background: rgba(255,255,255,0.15);
  }
  .timer-display {
    background: rgba(255,255,255,0.1); border: 2px solid rgba(255,255,255,0.3);
    border-radius: 8px; padding: 4px 14px; font-size: 22px; font-weight: 700;
    font-variant-numeric: tabular-nums; min-width: 90px; text-align: center;
    transition: background 0.3s;
  }
  .timer-display.urgent { background: rgba(231,76,60,0.5); border-color: #e74c3c; animation: pulse 1s infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.7; } }

  /* Phase progress */
  .phase-bar {
    background: #e8edf3; padding: 10px 24px;
    display: flex; align-items: center; gap: 0;
  }
  .phase-step {
    flex: 1; text-align: center; font-size: 12px; padding: 6px 4px; border-radius: 6px;
    color: var(--muted); cursor: default; position: relative; transition: all 0.3s;
  }
  .phase-step.active { background: white; font-weight: 700; box-shadow: var(--shadow); }
  .phase-step.done { color: var(--feedback); }
  .phase-step.feedback { background: #fff8e1; }
  .phase-step.feedback .step-num { background: #f39c12; color: white; }
  .phase-step .step-num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px; border-radius: 50%; font-weight: 700; font-size: 12px;
    background: var(--border); color: var(--muted); margin-right: 4px; transition: all 0.3s;
  }
  .phase-step.active .step-num { background: var(--primary); color: white; }
  .phase-step.done .step-num { background: var(--feedback); color: white; }

  /* Content */
  .ex-body { display: flex; gap: 20px; padding: 20px 24px; flex: 1; }

  /* Scenario panel */
  .scenario-panel { width: 300px; flex-shrink: 0; }
  .scenario-card {
    background: white; border-radius: var(--radius); box-shadow: var(--shadow);
    overflow: hidden; margin-bottom: 16px;
  }
  .scenario-header {
    padding: 14px 18px; font-weight: 700; font-size: 14px;
    display: flex; align-items: center; gap: 8px; color: white;
  }
  .phase-1-color { background: var(--phase1); }
  .phase-2-color { background: var(--phase2); }
  .phase-3-color { background: var(--phase3); }
  .phase-4-color { background: var(--feedback); }
  .scenario-body { padding: 16px 18px; font-size: 14px; line-height: 1.7; }
  .date-tag {
    display: inline-block; background: #fff3e0; color: #e65100;
    border-radius: 4px; padding: 2px 8px; font-size: 12px; font-weight: 700; margin-bottom: 8px;
  }

  /* Participants */
  .participants-card { background: white; border-radius: var(--radius); box-shadow: var(--shadow); }
  .participants-card h3 { padding: 14px 18px; font-size: 14px; border-bottom: 1px solid var(--border); }
  .participant-item {
    display: flex; align-items: center; gap: 10px; padding: 10px 18px;
    border-bottom: 1px solid #f0f4f8; font-size: 13px;
  }
  .participant-item:last-child { border-bottom: none; }
  .p-dot { width: 10px; height: 10px; border-radius: 50%; background: #ccc; }
  .p-dot.online { background: var(--feedback); }
  .p-dot.submitted { background: var(--primary); }
  .p-role { font-size: 11px; color: var(--muted); }

  /* Main work area */
  .work-area { flex: 1; display: flex; flex-direction: column; gap: 16px; min-width: 0; }

  /* My mission */
  .mission-card {
    background: white; border-radius: var(--radius); box-shadow: var(--shadow);
    border-left: 4px solid var(--primary); overflow: hidden;
  }
  .mission-card .mission-header {
    padding: 14px 18px 10px; font-weight: 700; font-size: 15px;
    display: flex; align-items: center; gap: 8px;
  }
  .my-role-badge {
    background: var(--primary); color: white; border-radius: 20px;
    padding: 3px 12px; font-size: 13px;
  }
  .mission-prompt { padding: 0 18px 12px; font-size: 14px; color: #2c3e50; line-height: 1.6; }
  .keyword-hint { padding: 10px 18px 14px; font-size: 12px; color: var(--muted); }
  .keyword-hint strong { color: var(--primary); }
  .kw-tag {
    display: inline-block; background: #eaf2ff; color: var(--primary);
    border-radius: 4px; padding: 2px 8px; margin: 2px; font-size: 11px; font-weight: 600;
  }
  .textarea-wrap { padding: 0 18px 16px; }
  .response-textarea {
    width: 100%; min-height: 140px; padding: 12px 14px;
    border: 2px solid var(--border); border-radius: 8px; font-size: 14px;
    font-family: inherit; line-height: 1.7; resize: vertical;
    transition: border-color 0.2s;
  }
  .response-textarea:focus { outline: none; border-color: var(--primary); }
  .response-textarea:disabled { background: #f7f9fc; color: var(--muted); }
  .submit-row { display: flex; justify-content: flex-end; padding: 0 18px 16px; gap: 10px; }
  .btn-submit {
    padding: 10px 24px; background: var(--primary); color: white;
    border: none; border-radius: 8px; font-size: 14px; font-weight: 700;
    cursor: pointer; font-family: inherit; transition: background 0.2s;
  }
  .btn-submit:hover { background: #244f7a; }
  .btn-submit.submitted { background: var(--feedback); cursor: default; }
  .btn-submit:disabled { background: #aaa; cursor: not-allowed; }

  /* Moderator only: no-mission card */
  .moderator-panel-card {
    background: white; border-radius: var(--radius); box-shadow: var(--shadow);
    padding: 20px 24px; border-left: 4px solid #f39c12;
  }
  .moderator-panel-card h3 { font-size: 15px; margin-bottom: 12px; color: #f39c12; }
  .btn-next-phase {
    padding: 12px 28px; border: none; border-radius: 8px; cursor: pointer;
    font-size: 15px; font-weight: 700; font-family: inherit;
    background: #e67e22; color: white; transition: background 0.2s; margin-right: 10px;
  }
  .btn-next-phase:hover { background: #cf6d17; }
  .btn-next-phase:disabled { background: #aaa; cursor: not-allowed; }
  .btn-start-timer {
    padding: 12px 28px; border: none; border-radius: 8px; cursor: pointer;
    font-size: 15px; font-weight: 700; font-family: inherit;
    background: #27ae60; color: white; transition: background 0.2s; margin-right: 10px;
  }
  .btn-start-timer:hover { background: #1e8449; }
  .btn-prev-phase {
    padding: 12px 22px; border: 2px solid #95a5a6; border-radius: 8px; cursor: pointer;
    font-size: 14px; font-weight: 700; font-family: inherit;
    background: white; color: #555; transition: all 0.2s; margin-right: 10px;
  }
  .btn-prev-phase:hover { border-color: var(--primary); color: var(--primary); background: #f0f6ff; }
  .ctrl-row { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }

  /* Other responses */
  .responses-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; }
  .response-card {
    background: white; border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden;
  }
  .response-card-header {
    padding: 10px 14px; font-size: 13px; font-weight: 700;
    display: flex; justify-content: space-between; align-items: center;
    background: #f7f9fc; border-bottom: 1px solid var(--border);
  }
  .response-status { font-size: 11px; font-weight: 400; }
  .status-waiting { color: var(--muted); }
  .status-typing { color: #e67e22; }
  .status-submitted { color: var(--feedback); font-weight: 600; }
  .response-text {
    padding: 12px 14px; font-size: 13px; color: var(--text); line-height: 1.7;
    min-height: 80px; white-space: pre-wrap;
  }
  .response-text.empty { color: var(--muted); font-style: italic; }

  /* Feedback screen */
  #screen-feedback { display: none; min-height: 100vh; }
  .fb-header {
    background: var(--feedback); color: white; padding: 20px 32px;
  }
  .fb-header h1 { font-size: 24px; font-weight: 700; margin-bottom: 4px; }
  .fb-header p { font-size: 14px; opacity: 0.85; }
  .fb-body { padding: 28px 32px; }
  .fb-phase-section { margin-bottom: 36px; }
  .fb-phase-title {
    font-size: 18px; font-weight: 700; margin-bottom: 16px;
    padding-bottom: 10px; border-bottom: 2px solid var(--border);
    display: flex; align-items: center; gap: 10px;
  }
  .fb-phase-badge {
    padding: 4px 14px; border-radius: 20px; color: white; font-size: 13px;
  }
  .fb-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px; }
  .fb-card {
    background: white; border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden;
  }
  .fb-card-header {
    padding: 12px 16px; font-weight: 700; font-size: 14px;
    background: var(--primary); color: white;
  }
  .my-fb-card { border: 2px solid var(--primary); box-shadow: 0 0 0 3px rgba(26,58,92,0.12); }
  .fb-section { padding: 14px 16px; border-bottom: 1px solid var(--border); }
  .fb-section:last-child { border-bottom: none; }
  .fb-section h4 { font-size: 12px; color: var(--muted); margin-bottom: 8px; font-weight: 600; }
  .fb-section p { font-size: 13px; line-height: 1.7; white-space: pre-wrap; }
  .fb-section p.empty { color: var(--muted); font-style: italic; }
  .keyword-check { margin-top: 8px; }
  .kw-found { display: inline-block; background: #d5f5e3; color: #1e8449; border-radius: 4px; padding: 2px 8px; margin: 2px; font-size: 11px; font-weight: 600; }
  .kw-miss { display: inline-block; background: #fadbd8; color: #922b21; border-radius: 4px; padding: 2px 8px; margin: 2px; font-size: 11px; font-weight: 600; }
  .score-badge {
    display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 700; margin-left: 8px;
  }
  .score-high { background: #d5f5e3; color: #1e8449; }
  .score-mid { background: #fef9e7; color: #b7950b; }
  .score-low { background: #fadbd8; color: #922b21; }
  .btn-restart {
    padding: 12px 32px; background: var(--primary); color: white; border: none;
    border-radius: 10px; font-size: 16px; font-weight: 700; cursor: pointer; font-family: inherit;
    margin-top: 24px; transition: background 0.2s;
  }
  .btn-restart:hover { background: #244f7a; }
  .fb-summary {
    background: white; border-radius: var(--radius); box-shadow: var(--shadow);
    padding: 20px 24px; margin-bottom: 28px; border-left: 4px solid var(--feedback);
  }
  .fb-summary h3 { font-size: 16px; margin-bottom: 8px; }
  .fb-summary p { font-size: 14px; color: var(--muted); line-height: 1.6; }
  .no-mission-notice {
    padding: 30px; text-align: center; color: var(--muted); font-size: 14px;
  }
  .waiting-screen {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    min-height: 300px; text-align: center; color: var(--muted);
  }
  .waiting-screen .wait-icon { font-size: 48px; margin-bottom: 16px; }
  .waiting-screen h2 { font-size: 20px; font-weight: 700; color: var(--primary); margin-bottom: 8px; }
  .waiting-screen p { font-size: 14px; line-height: 1.7; }
  .dot-blink::after { content: '...'; animation: dots 1.5s infinite; }
  @keyframes dots { 0% { content: '.'; } 33% { content: '..'; } 66% { content: '...'; } }
  .alert-box {
    background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px;
    padding: 12px 16px; font-size: 13px; color: #856404; margin: 0 18px 14px;
  }

  /* Lobby waiting */
  .lobby-view {
    flex: 1; display: flex; align-items: center; justify-content: center; flex-direction: column;
    gap: 20px; padding: 40px;
  }
  .lobby-card {
    background: white; border-radius: 16px; box-shadow: var(--shadow);
    padding: 40px 48px; text-align: center; max-width: 520px; width: 100%;
  }
  .lobby-card h2 { font-size: 22px; font-weight: 700; margin-bottom: 8px; color: var(--primary); }
  .lobby-card p { color: var(--muted); font-size: 14px; line-height: 1.7; }
  .my-role-display {
    display: inline-block; background: var(--primary); color: white;
    border-radius: 10px; padding: 10px 24px; font-size: 18px; font-weight: 700;
    margin: 16px 0;
  }
  .waiting-participants { margin-top: 20px; }
  .waiting-participants h4 { font-size: 13px; color: var(--muted); margin-bottom: 10px; }
</style>
</head>
<body>

<!-- ═══════════════════════════ LOGIN SCREEN ═══════════════════════════ -->
<div id="screen-login">
  <div class="login-card">
    <div class="login-logo">
      <span class="icon">🏫</span>
      <h1>인플루엔자 위기대응<br>협력 훈련 (도상훈련)</h1>
      <p>Tabletop Exercise · 감염병 대응 모의훈련</p>
    </div>

    <div class="form-group">
      <label>이름 (성명)</label>
      <input type="text" id="input-name" placeholder="예: 김선생" maxlength="20">
    </div>

    <div class="form-group">
      <label>역할 선택</label>
      <div class="role-grid" id="role-grid">
        <button class="role-btn moderator-btn" data-role="모더레이터">
          <span class="role-icon">🎙️</span>모더레이터 (진행자)<br><small style="opacity:0.7">훈련 진행 · 단계 통제</small>
        </button>
        <button class="role-btn" data-role="담임교사">
          <span class="role-icon">📚</span>담임교사
        </button>
        <button class="role-btn" data-role="보건교사">
          <span class="role-icon">🩺</span>보건교사
        </button>
        <button class="role-btn" data-role="행정실">
          <span class="role-icon">📋</span>행정실
        </button>
        <button class="role-btn" data-role="교장/교감">
          <span class="role-icon">🏛️</span>교장/교감
        </button>
      </div>
    </div>

    <button class="btn-join" id="btn-join" disabled>훈련 참가</button>
    <p class="session-hint">※ 같은 브라우저의 여러 탭에서 각자 역할을 선택하여 동시 참가하세요</p>
  </div>
</div>

<!-- ═══════════════════════════ EXERCISE SCREEN ═══════════════════════════ -->
<div id="screen-exercise">

  <!-- Header -->
  <div class="ex-header">
    <div class="title">
      🏥 인플루엔자 위기대응 협력 훈련
      <span id="my-role-header">역할: —</span>
    </div>
    <div class="phase-badge" id="phase-badge">대기 중</div>
    <div class="timer-display" id="timer-display">05:00</div>
  </div>

  <!-- Phase progress bar -->
  <div class="phase-bar">
    <div class="phase-step" id="step-0">
      <span class="step-num">0</span>대기실
    </div>
    <div class="phase-step" id="step-1">
      <span class="step-num">1</span>🛑 유증상자 발견
    </div>
    <div class="phase-step" id="step-2">
      <span class="step-num">2</span>🚨 확진자 발생
    </div>
    <div class="phase-step" id="step-3">
      <span class="step-num">3</span>💥 집단 유행 발생
    </div>
    <div class="phase-step" id="step-4">
      <span class="step-num">4</span>💡 피드백·토의
    </div>
  </div>

  <!-- Body -->
  <div class="ex-body" id="ex-body">
    <!-- Dynamic content -->
  </div>

</div>

<!-- ═══════════════════════════ FEEDBACK SCREEN ═══════════════════════════ -->
<div id="screen-feedback">
  <div class="fb-header">
    <h1>💡 피드백 및 평가 결과</h1>
    <p>각 역할별 작성 내용을 정답 키워드와 비교하여 누락된 항목을 확인하고 개선점을 논의합니다.</p>
  </div>
  <div class="fb-body" id="fb-body">
    <!-- Dynamic content -->
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════════
//  DATA: 시나리오 & 정답 키워드
// ═══════════════════════════════════════════════════════
const PHASES = [
  {
    id: 1,
    title: '유증상자 발견',
    emoji: '🛑',
    color: '#e67e22',
    colorClass: 'phase-1-color',
    date: '3월 5일 (화)',
    situation: '1학년 6반 진한이가 수업 중 고열과 심한 기침, 가슴 통증을 호소합니다. 담임교사가 진한이의 안색이 매우 좋지 않고 발열이 의심됨을 발견했습니다.',
    duration: 300,
    missions: {
      '담임교사': {
        prompt: '진한이와 남은 반 학생들을 위해 당장 무엇을 해야 할까요?',
        answer: '① 즉시 보건교사에게 유선으로 연락합니다.\n② 진한이에게 마스크를 착용시키고, 2m 이상 거리를 유지하며 보건실까지 직접 동행합니다.\n③ 교실 창문을 모두 열어 충분히 환기시킵니다.\n④ 나머지 학생들에게도 마스크 착용을 지도합니다.',

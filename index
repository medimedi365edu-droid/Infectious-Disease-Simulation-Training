  // Scenario panel
  const scenarioHtml = `
    <div class="scenario-panel">
      <div class="scenario-card">
        <div class="scenario-header ${phase.colorClass}">
          ${phase.emoji} ${state.currentPhase}단계 상황
        </div>
        <div class="scenario-body">
          <div class="date-tag">📅 ${phase.date}</div>
          <p>${phase.situation}</p>
        </div>
      </div>

      <div class="participants-card">
        <h3>👥 참가자 현황</h3>
        ${renderParticipantsList(state, state.currentPhase)}
      </div>
    </div>`;

  // My work area
  let workHtml = '';
  if (myRole === '모더레이터') {
    // Show moderator controls + all responses
    workHtml = `
      <div class="work-area">
        <div class="moderator-panel-card">
          <h3>🎙️ 진행자 컨트롤 패널</h3>
          <p style="font-size:13px;color:var(--muted);margin-bottom:14px">타이머를 시작하거나 단계를 진행합니다.</p>
          <div class="ctrl-row">
            ${state.currentPhase > 0 ? `<button class="btn-prev-phase" onclick="prevPhase()">◀ 이전 단계</button>` : ''}
            ${state.timerRunning
              ? `<button class="btn-next-phase" onclick="nextPhase()" style="background:#8e44ad">⏭ 지금 피드백 보기</button>`
              : `<button class="btn-start-timer" onclick="startTimer()">▶ 타이머 시작</button>
                 <button class="btn-next-phase" onclick="nextPhase()">💡 피드백 보기</button>`
            }
          </div>
        </div>
        <div>
          <h3 style="font-size:15px;font-weight:700;margin-bottom:12px">📝 전체 작성 현황</h3>
          <div class="responses-grid">
            ${renderAllRoleCards(phase, phaseResponses, '')}
          </div>
        </div>
      </div>`;
  } else if (!myMission) {
    workHtml = `
      <div class="work-area">
        <div class="no-mission-notice">
          <p style="font-size:32px;margin-bottom:12px">📌</p>
          <p style="font-size:16px;font-weight:700;color:var(--primary);margin-bottom:8px">이 단계에서 ${myRole}의 직접 미션은 없습니다</p>
          <p style="font-size:14px;line-height:1.7">다른 역할의 작성 내용을 확인하면서 상황을 파악하세요.</p>
        </div>
        <div>
          <h3 style="font-size:15px;font-weight:700;margin-bottom:12px">📝 다른 역할 작성 현황</h3>
          <div class="responses-grid">
            ${renderAllRoleCards(phase, phaseResponses, myRole)}
          </div>
        </div>
      </div>`;
  } else {
    workHtml = `
      <div class="work-area">
        ${!state.timerRunning && !submitted ? `<div class="alert-box">⏳ 모더레이터가 타이머를 시작하면 작성을 시작할 수 있습니다.</div>` : ''}
        <div class="mission-card">
          <div class="mission-header">
            <span class="my-role-badge">${ROLE_ICONS[myRole] || ''} ${myRole}</span>
            <span style="font-size:14px;color:var(--muted)">나의 미션</span>
          </div>
          <div class="mission-prompt">${myMission.prompt}</div>
          <div class="keyword-hint">
            <strong>참고 키워드:</strong>
            ${myMission.keywords.map(k => `<span class="kw-tag">${k}</span>`).join('')}
          </div>
          <div class="textarea-wrap">
            <textarea
              class="response-textarea"
              id="my-textarea"
              placeholder="여기에 조치 사항을 자유롭게 작성하세요..."
              ${submitted ? 'disabled' : ''}
            >${escapeHtml(myResponse)}</textarea>
          </div>
          <div class="submit-row">
            ${submitted
              ? `<button class="btn-submit submitted" disabled>✅ 제출 완료</button>`
              : `<button class="btn-submit" onclick="submitResponse()" ${!state.timerRunning ? 'disabled' : ''}>제출하기</button>`
            }
          </div>
        </div>
        <div>
          <h3 style="font-size:15px;font-weight:700;margin-bottom:12px">📝 다른 역할 작성 현황</h3>
          <div class="responses-grid">
            ${renderAllRoleCards(phase, phaseResponses, myRole)}
          </div>
        </div>
      </div>`;
  }

  body.innerHTML = scenarioHtml + workHtml;

  // 제출 완료 또는 단계 종료 시 인라인 피드백 추가
  if (submitted || myRole === '모더레이터' || !state.timerRunning) {
    const workAreaEl = body.querySelector('.work-area');
    if (workAreaEl) {
      workAreaEl.insertAdjacentHTML('beforeend', buildInlineFeedbackHtml(phase, phaseResponses));
    }
  }

  // Attach textarea live-save (debounced: 600ms)
  const ta = document.getElementById('my-textarea');
  if (ta) {
    let draftTimer = null;
    ta.addEventListener('input', () => {
      clearTimeout(draftTimer);
      draftTimer = setTimeout(() => saveMyDraft(ta.value), 600);
    });
    ta.addEventListener('blur', () => {
      clearTimeout(draftTimer);
      saveMyDraft(ta.value);
      if (pendingRender) { pendingRender = false; renderExercise(); }
    });
  }
}

function buildInlineFeedbackHtml(phase, phaseResponses) {
  const cards = Object.entries(phase.missions).map(([role, mission]) => {
    const text = phaseResponses[role] || '';
    const found = mission.keywords.filter(kw =>
      text.includes(kw.split('·')[0].replace(/[·\/]/g, '').substring(0, 4))
    );
    const score = mission.keywords.length > 0
      ? Math.round(found.length / mission.keywords.length * 100) : 100;
    const scoreClass = score >= 80 ? 'score-high' : score >= 50 ? 'score-mid' : 'score-low';
    const isMe = role === myRole;
    return `
      <div class="fb-card ${isMe ? 'my-fb-card' : ''}">
        <div class="fb-card-header">
          ${ROLE_ICONS[role] || ''} ${role}
          ${isMe ? '<span style="font-size:11px;opacity:0.8;margin-left:4px">(나)</span>' : ''}
          <span class="score-badge ${scoreClass}" style="float:right">${score}점</span>
        </div>
        <div class="fb-section">
          <h4>📝 작성 내용</h4>
          <p class="${!text ? 'empty' : ''}">${text ? escapeHtml(text) : '작성 내용 없음'}</p>
        </div>
        <div class="fb-section">
          <h4>✅ 키워드 확인</h4>
          <div class="keyword-check">
            ${mission.keywords.map(kw => {
              const hit = text.includes(kw.split('·')[0].replace(/[·\/]/g, '').substring(0, 4));
              return `<span class="${hit ? 'kw-found' : 'kw-miss'}">${hit ? '✓' : '✗'} ${kw}</span>`;
            }).join('')}
          </div>
        </div>
        <div class="fb-section">
          <h4>📌 모범 답안</h4>
          <p style="font-size:12px;color:#555;line-height:1.7">${escapeHtml(mission.answer)}</p>
        </div>
      </div>`;
  }).join('');

  return `
    <div style="margin-top:24px;padding-top:20px;border-top:2px solid var(--border)">
      <h3 style="font-size:15px;font-weight:700;margin-bottom:14px">📊 피드백 — 키워드 체크</h3>
      <div class="fb-grid">${cards}</div>
    </div>`;
}

function renderPhaseFeedback(body, state) {
  const phase = PHASES[state.currentPhase - 1];
  const phaseResponses = (state.responses || {})[`phase${state.currentPhase}`] || {};
  const isLast = state.currentPhase === 3;

  const cards = Object.entries(phase.missions).map(([role, mission]) => {
    const text = phaseResponses[role] || '';
    const found = mission.keywords.filter(kw => text.includes(kw.split('·')[0].replace(/[·\/]/g, '').substring(0, 4)));
    const score = mission.keywords.length > 0 ? Math.round(found.length / mission.keywords.length * 100) : 100;
    const scoreClass = score >= 80 ? 'score-high' : score >= 50 ? 'score-mid' : 'score-low';
    const isMe = role === myRole;
    return `
      <div class="fb-card ${isMe ? 'my-fb-card' : ''}">
        <div class="fb-card-header">
          ${ROLE_ICONS[role] || ''} ${role} ${isMe ? '<span style="font-size:11px;opacity:0.8">(나)</span>' : ''}
          <span class="score-badge ${scoreClass}" style="float:right">${score}점</span>
        </div>
        <div class="fb-section">
          <h4>📝 작성 내용</h4>
          <p class="${!text ? 'empty' : ''}">${text ? escapeHtml(text) : '작성 내용 없음'}</p>
        </div>
        <div class="fb-section">
          <h4>✅ 키워드 확인</h4>
          <div class="keyword-check">
            ${mission.keywords.map(kw => {
              const hit = text.includes(kw.split('·')[0].replace(/[·\/]/g, '').substring(0, 4));
              return `<span class="${hit ? 'kw-found' : 'kw-miss'}">${hit ? '✓' : '✗'} ${kw}</span>`;
            }).join('')}
          </div>
        </div>
        <div class="fb-section">
          <h4>📌 모범 답안</h4>
          <p style="font-size:12px;color:#555;line-height:1.7">${escapeHtml(mission.answer)}</p>
        </div>
      </div>`;
  }).join('');

  const modControls = myRole === '모더레이터' ? `
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px">
      <button class="btn-prev-phase" onclick="prevPhase()">◀ ${state.currentPhase}단계로 돌아가기</button>
      <button class="btn-next-phase" onclick="nextPhase()">
        ${isLast ? '💡 최종 피드백 보기' : `▶ ${state.currentPhase + 1}단계 시작`}
      </button>
    </div>` : `<p style="font-size:13px;color:var(--muted);margin-top:6px">모더레이터가 다음 단계를 진행합니다.</p>`;

  body.innerHTML = `
    <div style="flex:1">
      <div class="fb-summary" style="margin-bottom:20px">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px">
          <div>
            <h3 style="display:flex;align-items:center;gap:8px">
              <span style="background:${phase.color};color:white;border-radius:6px;padding:3px 10px;font-size:13px">${phase.emoji} ${state.currentPhase}단계</span>
              피드백 — ${phase.title}
            </h3>
            <p style="font-size:13px;color:var(--muted);margin-top:6px">📅 ${phase.date} · 작성 내용을 정답 키워드와 비교하여 누락 항목을 확인하세요.</p>
          </div>
          ${modControls}
        </div>
      </div>
      <div class="fb-grid">${cards}</div>
    </div>`;
}

function renderParticipantsList(state, phaseNum) {
  const participants = state.participants || {};
  const responses = state.responses || {};
  const phaseResponses = responses[`phase${phaseNum}`] || {};

  const roles = ['모더레이터', '담임교사', '보건교사', '행정실', '교장/교감'];
  return roles.map(role => {
    const p = participants[role];
    if (!p) return `
      <div class="participant-item">
        <div class="p-dot"></div>
        <div>
          <div>${ROLE_ICONS[role] || ''} ${role}</div>
          <div class="p-role">미접속</div>
        </div>
      </div>`;
    const submitted = phaseResponses[`${role}_submitted`];
    const hasText = phaseResponses[role] && phaseResponses[role].length > 0;
    return `
      <div class="participant-item">
        <div class="p-dot ${submitted ? 'submitted' : 'online'}"></div>
        <div>
          <div>${ROLE_ICONS[role] || ''} ${role}</div>
          <div class="p-role">${p.name} · ${submitted ? '✅ 제출완료' : hasText ? '✏️ 작성중' : '대기중'}</div>
        </div>
      </div>`;
  }).join('');
}

function renderAllRoleCards(phase, phaseResponses, excludeRole) {
  const roles = ['담임교사', '보건교사', '행정실', '교장/교감'];
  return roles
    .filter(role => role !== excludeRole)
    .map(role => {
      const mission = phase.missions[role];
      const text = phaseResponses[role] || '';
      const submitted = phaseResponses[`${role}_submitted`] || false;
      const statusClass = submitted ? 'status-submitted' : text ? 'status-typing' : 'status-waiting';
      const statusText = submitted ? '✅ 제출완료' : text ? '✏️ 작성중...' : '대기중';
      return `
        <div class="response-card">
          <div class="response-card-header">
            <span>${ROLE_ICONS[role] || ''} ${role}</span>
            <span class="response-status ${statusClass}">${statusText}</span>
          </div>
          <div class="response-text ${!text ? 'empty' : ''}">
            ${text ? escapeHtml(text) : '아직 작성 내용이 없습니다.'}
          </div>
        </div>`;
    }).join('');
}

function renderFeedbackTransition() {
  document.getElementById('screen-exercise').style.display = 'none';
  document.getElementById('screen-feedback').style.display = 'block';
  renderFeedback();
}

// ═══════════════════════════════════════════════════════
//  ACTIONS
// ═══════════════════════════════════════════════════════
function startPhase(phaseNum) {
  if (myRole !== '모더레이터') return;
  const state = getState();
  state.currentPhase = phaseNum;
  state.phaseStartTime = Date.now();
  state.timerRunning = true;
  state.showingFeedback = false;
  saveState(state);
  broadcast('PHASE_CHANGE', { phase: phaseNum });
  renderExercise();
}

function startTimer() {
  if (myRole !== '모더레이터') return;
  const state = getState();
  state.phaseStartTime = Date.now();
  state.timerRunning = true;
  saveState(state);
  broadcast('STATE_CHANGED', {});
  renderExercise();
}

function nextPhase() {
  if (myRole !== '모더레이터') return;
  const state = getState();
  if (!state.showingFeedback) {
    // 현재 단계 → 피드백 화면
    state.timerRunning = false;
    state.showingFeedback = true;
    saveState(state);
    broadcast('PHASE_CHANGE', {});
    renderExercise();
  } else {
    // 피드백 → 다음 단계
    const next = state.currentPhase + 1;
    if (next > 4) return;
    if (next <= 3) {
      startPhase(next);
    } else {
      state.currentPhase = 4;
      state.timerRunning = false;
      state.showingFeedback = false;
      saveState(state);
      broadcast('PHASE_CHANGE', { phase: 4 });
      renderExercise();
    }
  }
}

function prevPhase() {
  if (myRole !== '모더레이터') return;
  const state = getState();
  if (state.showingFeedback) {
    // 피드백 → 현재 단계로 복귀
    state.showingFeedback = false;
    saveState(state);
    broadcast('PHASE_CHANGE', {});
    renderExercise();
  } else {
    const prev = state.currentPhase - 1;
    if (prev < 0) return;
    state.currentPhase = prev;
    state.timerRunning = false;
    state.phaseStartTime = null;
    state.showingFeedback = false;
    saveState(state);
    broadcast('PHASE_CHANGE', { phase: prev });
    renderExercise();
  }
}

function goBackFromFeedback() {
  if (myRole !== '모더레이터') return;
  const state = getState();
  state.currentPhase = 3;
  state.timerRunning = false;
  state.phaseStartTime = null;
  saveState(state);
  broadcast('PHASE_CHANGE', { phase: 3 });
  document.getElementById('screen-feedback').style.display = 'none';
  document.getElementById('screen-exercise').style.display = 'flex';
  renderExercise();
}

function saveMyDraft(text) {
  const state = getState();
  if (!state.responses) state.responses = {};
  const key = `phase${state.currentPhase}`;
  if (!state.responses[key]) state.responses[key] = {};
  state.responses[key][myRole] = text;
  saveState(state);
  broadcast('RESPONSE_UPDATE', {});
}

function submitResponse() {
  const ta = document.getElementById('my-textarea');
  const text = ta ? ta.value.trim() : '';
  const state = getState();
  if (!state.responses) state.responses = {};
  const key = `phase${state.currentPhase}`;
  if (!state.responses[key]) state.responses[key] = {};
  state.responses[key][myRole] = text;
  state.responses[key][`${myRole}_submitted`] = true;
  saveState(state);
  broadcast('RESPONSE_UPDATE', {});
  renderExercise();
}

// ═══════════════════════════════════════════════════════
//  FEEDBACK SCREEN
// ═══════════════════════════════════════════════════════
function renderFeedback() {
  const state = getState();
  const responses = state.responses || {};
  const fb = document.getElementById('fb-body');

  let html = `
    <div class="fb-summary">
      ${myRole === '모더레이터' ? `<button class="btn-prev-phase" style="margin-bottom:14px" onclick="goBackFromFeedback()">◀ 3단계로 돌아가기</button><br>` : ''}
      <h3>훈련 완료 — 피드백 및 토의 시간 (5분)</h3>
      <p>아래 각 역할별 작성 내용을 정답 키워드와 비교하여 누락된 항목을 확인하고,<br>
      우리 학교 상황에 맞게 보완할 점을 모더레이터 주도하에 함께 토의합니다.</p>
    </div>`;

  PHASES.forEach(phase => {
    const phaseResponses = responses[`phase${phase.id}`] || {};
    html += `
      <div class="fb-phase-section">
        <div class="fb-phase-title">
          <span class="fb-phase-badge" style="background:${phase.color}">${phase.emoji} ${phase.id}단계</span>
          ${phase.title}
          <small style="color:var(--muted);font-weight:400;font-size:13px">${phase.date}</small>
        </div>
        <div class="fb-grid">
          ${Object.entries(phase.missions).map(([role, mission]) => {
            const text = phaseResponses[role] || '';
            const submitted = phaseResponses[`${role}_submitted`] || false;
            const found = mission.keywords.filter(kw => text.includes(kw.replace('·', '').split('·')[0]));
            const missed = mission.keywords.filter(kw => !text.includes(kw.replace('·', '').split('·')[0]));
            const score = mission.keywords.length > 0 ? Math.round((found.length / mission.keywords.length) * 100) : 100;
            const scoreClass = score >= 80 ? 'score-high' : score >= 50 ? 'score-mid' : 'score-low';
            return `
              <div class="fb-card">
                <div class="fb-card-header">
                  ${ROLE_ICONS[role] || ''} ${role}
                  <span class="score-badge ${scoreClass}" style="float:right">${score}점</span>
                </div>
                <div class="fb-section">
                  <h4>📝 작성한 내용 ${submitted ? '(제출완료)' : '(미제출)'}</h4>
                  <p class="${!text ? 'empty' : ''}">${text ? escapeHtml(text) : '작성 내용 없음'}</p>
                </div>
                <div class="fb-section">
                  <h4>✅ 정답 키워드 확인</h4>
                  <div class="keyword-check">
                    ${mission.keywords.map(kw => {
                      const isFound = text.includes(kw.split('·')[0].replace(/[·\/]/g, '').substring(0, 5));
                      return `<span class="${isFound ? 'kw-found' : 'kw-miss'}">${isFound ? '✓' : '✗'} ${kw}</span>`;
                    }).join('')}
                  </div>
                </div>
                <div class="fb-section">
                  <h4>📌 모범 답안</h4>
                  <p style="font-size:12px;color:#555">${escapeHtml(mission.answer)}</p>
                </div>
              </div>`;
          }).join('')}
        </div>
      </div>`;
  });

  html += `
    <div style="text-align:center;padding:20px 0 40px">
      <button class="btn-restart" onclick="resetAll()">🔄 훈련 다시 시작</button>
    </div>`;

  fb.innerHTML = html;
}

function resetAll() {
  if (confirm('훈련을 처음부터 다시 시작하시겠습니까? 모든 응답이 초기화됩니다.')) {
    localStorage.removeItem(STORAGE_KEY);
    broadcast('STATE_CHANGED', {});
    location.reload();
  }
}

// ═══════════════════════════════════════════════════════
//  UTILS
// ═══════════════════════════════════════════════════════
function escapeHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/\n/g, '<br>');
}

// Handle already-started session on page load
window.addEventListener('load', () => {
  const state = getState();
  // Auto-transition to feedback if phase is 4
  if (state.currentPhase === 4 && document.getElementById('screen-exercise').style.display !== 'none') {
    renderFeedbackTransition();
  }
});
</script>
</body>
</html>

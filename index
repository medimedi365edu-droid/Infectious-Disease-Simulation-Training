// ═══════════════════════════════════════════════════════
//  STATE & SYNC
// ═══════════════════════════════════════════════════════
const STORAGE_KEY = 'ttx_influenza_v3';
const CHANNEL_NAME = 'ttx_influenza_ch';
let myName = '';
let myRole = '';
let channel;
let timerInterval = null;
let pendingRender = false;

function getState() {
  try {
    return JSON.parse(localStorage.getItem(STORAGE_KEY)) || defaultState();
  } catch { return defaultState(); }
}

function defaultState() {
  return {
    currentPhase: 0,
    phaseStartTime: null,
    timerRunning: false,
    showingFeedback: false,
    participants: {},
    responses: {}
  };
}

function saveState(state) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
}

function broadcast(type, data) {
  if (channel) channel.postMessage({ type, data, from: myRole });
}

function isTyping() {
  const ta = document.getElementById('my-textarea');
  return ta && document.activeElement === ta;
}

function initChannel() {
  channel = new BroadcastChannel(CHANNEL_NAME);
  channel.onmessage = (e) => {
    const { type } = e.data;
    if (type === 'STATE_CHANGED' || type === 'RESPONSE_UPDATE' || type === 'PHASE_CHANGE') {
      if (isTyping()) { pendingRender = true; return; }
      renderExercise();
    }
  };
}

// ═══════════════════════════════════════════════════════
//  LOGIN
// ═══════════════════════════════════════════════════════
let selectedRole = '';

document.querySelectorAll('.role-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    selectedRole = btn.dataset.role;
    updateJoinBtn();
  });
});

document.getElementById('input-name').addEventListener('input', updateJoinBtn);

function updateJoinBtn() {
  const name = document.getElementById('input-name').value.trim();
  document.getElementById('btn-join').disabled = !(name && selectedRole);
}

document.getElementById('btn-join').addEventListener('click', () => {
  const name = document.getElementById('input-name').value.trim();
  if (!name || !selectedRole) return;

  myName = name;
  myRole = selectedRole;

  initChannel();

  // Register participant
  const state = getState();
  state.participants[myRole] = { name: myName, joinedAt: Date.now() };
  saveState(state);
  broadcast('STATE_CHANGED', {});

  document.getElementById('screen-login').style.display = 'none';
  document.getElementById('screen-exercise').style.display = 'flex';
  document.getElementById('my-role-header').textContent = `역할: ${ROLE_ICONS[myRole] || ''} ${myRole} (${myName})`;

  renderExercise();
  startPolling();
});

// ═══════════════════════════════════════════════════════
//  POLLING (fallback for same-device sync)
// ═══════════════════════════════════════════════════════
let lastStateStr = '';
function startPolling() {
  setInterval(() => {
    const cur = localStorage.getItem(STORAGE_KEY);
    if (cur !== lastStateStr) {
      lastStateStr = cur;
      if (isTyping()) { pendingRender = true; return; }
      renderExercise();
    }
  }, 500);
}

// ═══════════════════════════════════════════════════════
//  TIMER
// ═══════════════════════════════════════════════════════
function getTimeRemaining() {
  const state = getState();
  if (!state.phaseStartTime || !state.timerRunning) return null;
  const phase = PHASES[state.currentPhase - 1];
  if (!phase) return null;
  const elapsed = Math.floor((Date.now() - state.phaseStartTime) / 1000);
  return Math.max(0, phase.duration - elapsed);
}

function formatTime(seconds) {
  if (seconds === null || seconds === undefined) return '05:00';
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
}

function updateTimerDisplay() {
  const state = getState();
  const el = document.getElementById('timer-display');
  if (!el) return;

  const remaining = getTimeRemaining();
  if (remaining === null) {
    const phase = PHASES[state.currentPhase - 1];
    el.textContent = phase ? formatTime(phase.duration) : '05:00';
    el.classList.remove('urgent');
    return;
  }
  el.textContent = formatTime(remaining);
  el.classList.toggle('urgent', remaining <= 60 && remaining > 0);

  // Timer 0: 피드백 화면으로 자동 전환 (moderator only)
  if (remaining === 0 && myRole === '모더레이터' && state.timerRunning) {
    const s = getState();
    s.timerRunning = false;
    s.showingFeedback = true;
    saveState(s);
    broadcast('PHASE_CHANGE', {});
  }
}

function startTimerLoop() {
  if (timerInterval) clearInterval(timerInterval);
  timerInterval = setInterval(updateTimerDisplay, 500);
}
startTimerLoop();

// ═══════════════════════════════════════════════════════
//  RENDER
// ═══════════════════════════════════════════════════════
function renderExercise() {
  const state = getState();
  updatePhaseBar(state);
  updatePhaseBadge(state);
  renderBody(state);
}

function updatePhaseBar(state) {
  for (let i = 0; i <= 4; i++) {
    const el = document.getElementById(`step-${i}`);
    if (!el) continue;
    el.classList.remove('active', 'done', 'feedback');
    if (i === state.currentPhase) {
      el.classList.add('active');
      if (state.showingFeedback) el.classList.add('feedback');
    } else if (i < state.currentPhase) el.classList.add('done');
  }
}

function updatePhaseBadge(state) {
  const badge = document.getElementById('phase-badge');
  if (!badge) return;
  if (state.currentPhase === 0) badge.textContent = '대기 중';
  else if (state.currentPhase <= 3) badge.textContent = state.showingFeedback ? `${state.currentPhase}단계 피드백` : `${state.currentPhase}단계`;
  else badge.textContent = '최종 피드백';
}

function renderBody(state) {
  const body = document.getElementById('ex-body');
  if (!body) return;

  if (state.currentPhase === 0) {
    renderLobby(body, state);
  } else if (state.currentPhase >= 1 && state.currentPhase <= 3) {
    if (state.showingFeedback) renderPhaseFeedback(body, state);
    else renderPhase(body, state);
  } else if (state.currentPhase === 4) {
    renderFeedbackTransition();
  }
}

